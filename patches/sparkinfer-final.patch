+    @cute.jit
+    def _activate_routes(
+        self,
+        fc1_flat: cute.Tensor,
+        activated_flat: cute.Tensor,
+        rotations_flat: cute.Tensor,
+        global_ids: cute.Tensor,
+        tier_map: cute.Tensor,
+        tid: Int32,
+        cta: Int32,
+        grid_x: Int32,
+        active_m: Int32,
